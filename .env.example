# ============================================================
#  FundForge AI — Environment Variables
#  Copy this file to .env and fill in your values.
#  Never commit the real .env file to version control.
# ============================================================

# ----- IBM watsonx.ai ----------------------------------------
IBM_API_KEY=your_IBM_api_key;
IBM_PROJECT_ID=your_IBM_project_id;
IBM_REGION=
IBM_URL=
IBM_GRANITE_MODEL_ID=

GEMINI_API_KEY=your_gemini_api_key
GROQ_API_KEY=your_groq_api_key


# ----- IBM Vector Index (RAG) --------------------------------
VECTOR_INDEX_ID=
VECTOR_INDEX_INSTANCE_ID=

# ----- Google Search -----------------------------------------
GOOGLE_SEARCH_API_KEY=
GOOGLE_CSE_ID=

# ----- Flask / Backend ---------------------------------------
SECRET_KEY=
FLASK_ENV=development
FLASK_PORT=5000
FLASK_DEBUG=true

# ----- Database ----------------------------------------------
DATABASE_URL=

# ----- Frontend (Vite) ---------------------------------------
VITE_API_BASE_URL=http://localhost:5000/api
VITE_APP_NAME=FundForge AI

# ----- CORS --------------------------------------------------
ALLOWED_ORIGINS=http://localhost:5173
